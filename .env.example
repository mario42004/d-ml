APP_ENV=development
APP_URL=https://d-ml.eu

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

AUTH_SECRET_KEY=change-this-secret-key
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=14

FTP_HOST=d-ml.eu
FTP_PORT=22
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
FTP_REMOTE_PATH=/html
FTP_PROTOCOL=sftp

# Production endpoint exposed by nginx on 443.
AUDIOPRINT_AUDIOANALISYS_API_URL=https://api.d-ml.eu/audioanalisys
# Local same-host alternative for development:
# AUDIOPRINT_AUDIOANALISYS_API_URL=http://127.0.0.1:8001/audioanalisys
# Backward-compatible fallback if already configured in an older deployment.
AUDIOPRINT_SCALOGRAM_API_URL=https://api.d-ml.eu/audioanalisys
AUDIOPRINT_MAX_UPLOAD_MB=25
AUDIOPRINT_UPLOAD_TIMEOUT_SECONDS=120
